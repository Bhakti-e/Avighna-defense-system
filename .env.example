# AVIGHNA Defense System - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to GitHub

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/avighna_defense
# For local development: sqlite:///./avighna_defense.db
# For Neon: postgresql://user:password@ep-xxx.neon.tech/avighna_defense
# For Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# For Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway

# ============================================================================
# SECURITY (CRITICAL - CHANGE THESE IN PRODUCTION)
# ============================================================================
SECRET_KEY=your-secret-key-minimum-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================
NETWORK_CIDR=192.168.0.0/24
NETWORK_SCAN_INTERVAL=300
NETWORK_MONITORING_ENABLED=true

# ============================================================================
# CORS CONFIGURATION (Update with your deployed frontend URL)
# ============================================================================
FRONTEND_URL=http://localhost:3000
# For production: https://your-app.vercel.app

# ============================================================================
# THREAT INTELLIGENCE API KEYS (Optional - for future integration)
# ============================================================================
# CISA_API_KEY=your-cisa-api-key-here
# MITRE_API_KEY=your-mitre-api-key-here
# ALIENVAULT_API_KEY=your-alienvault-api-key-here
# VIRUSTOTAL_API_KEY=your-virustotal-api-key-here
# ABUSEIPDB_API_KEY=your-abuseipdb-api-key-here
# THREATFOX_API_KEY=your-threatfox-api-key-here

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
# For production: https://your-backend.onrender.com or https://your-backend.railway.app

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=backend.log

# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================================================
# PORT=8000  # Render/Railway will set this automatically
# PYTHON_VERSION=3.11  # For Railway

